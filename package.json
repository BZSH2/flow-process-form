{
  "name": "a",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:stylelint": "stylelint \"src/**/*.{css,scss,sass}\" --max-warnings=0",
    "lint-staged": "lint-staged",
    "commit": "git-cz",
    "cz": "esno scripts/commit.ts && npm run commit",
    "commitlint": "commitlint --edit",
    "prepare": "husky",
    "preview": "vite preview",
    "openI18n": "dotenv -e .env.i18n -- esno scripts/GenerateI18n/index.ts"
  },
  "dependencies": {
    "@logicflow/core": "^2.1.11",
    "@logicflow/extension": "^2.1.15",
    "antd": "^6.3.5",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.4",
    "js-cookies": "^1.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/types": "^20.0.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/preset-uno": "^66.6.7",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "esno": "^4.8.0",
    "git-cz": "^4.9.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.4.1",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "sass": "^1.99.0",
    "stylelint": "^16.26.0",
    "stylelint-config-standard": "^38.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "unocss": "^66.6.7",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-react-components": "^0.1.4",
    "vite": "^8.0.4",
    "vite-plugin-svg-icons": "^2.0.1"
  }
}
